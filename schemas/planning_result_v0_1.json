{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanningResult v0.1",
  "type": "object",
  "required": ["schema_version", "frame_id", "timestamp_s", "behavior", "confidence"],
  "properties": {
    "schema_version": { "type": "string", "const": "planning.v0.1" },
    "frame_id": { "type": "integer", "minimum": 0 },
    "timestamp_s": { "type": "number", "minimum": 0 },
    "coordinate_frame": { "type": "string" },
    "units": { "type": "object" },
    "target_path": { "type": "array" },
    "target_speed_mps": { "type": ["number", "null"] },
    "behavior": {
      "type": "string",
      "enum": [
        "KEEP_LANE",
        "FOLLOW_LEAD",
        "STOP_FOR_RED",
        "GO_CAUTION",
        "YIELD_VRU",
        "LANE_DEPARTURE",
        "CAUTION",
        "UNKNOWN"
      ]
    },
    "warnings": { "type": "array" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "lead_object_id": { "type": ["integer", "null"] },
    "stop_reason": { "type": ["string", "null"] },
    "target_path_px": { "type": "array" },
    "debug": { "type": "object" }
  }
}
